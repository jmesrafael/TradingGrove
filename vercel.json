{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                "destination": "/src/pages/index.html" },
    { "source": "/auth",            "destination": "/src/pages/auth.html" },
    { "source": "/dashboard",       "destination": "/src/pages/dashboard.html" },
    { "source": "/journal",         "destination": "/src/pages/journal.html" },
    { "source": "/analytics",       "destination": "/src/pages/analytics.html" },
    { "source": "/calendar",        "destination": "/src/pages/calendar.html" },
    { "source": "/notes",           "destination": "/src/pages/notes.html" },
    { "source": "/calculator",      "destination": "/src/pages/calculators/position-calculator.html" },
    { "source": "/subscription",    "destination": "/src/pages/subscription.html" },
    { "source": "/confirm",         "destination": "/src/pages/confirm.html" },
    { "source": "/reset-password",  "destination": "/src/pages/reset-password.html" },
    { "source": "/pricing",         "destination": "/src/pages/pricing.html" },
    { "source": "/help",            "destination": "/src/pages/help.html" },
    { "source": "/terms",           "destination": "/src/pages/terms.html" },
    { "source": "/privacy",         "destination": "/src/pages/privacy.html" },
    { "source": "/refund",          "destination": "/src/pages/refund.html" },
    { "source": "/profile",         "destination": "/src/pages/profile.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|otf|png|jpg|jpeg|gif|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/src/assets/favicon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ]
}
