{
  "buildCommand": "node build.js",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                "destination": "/index.html" },
    { "source": "/auth",            "destination": "/auth.html" },
    { "source": "/dashboard",       "destination": "/dashboard.html" },
    { "source": "/journal",         "destination": "/journal.html" },
    { "source": "/logs",            "destination": "/logs.html" },
    { "source": "/presession",      "destination": "/presession.html" },
    { "source": "/analytics",       "destination": "/analytics.html" },
    { "source": "/calendar",        "destination": "/calendar.html" },
    { "source": "/notes",           "destination": "/notes.html" },
    { "source": "/calculator",      "destination": "/calculators/position-calculator.html" },
    { "source": "/subscription",    "destination": "/subscription.html" },
    { "source": "/confirm",         "destination": "/confirm.html" },
    { "source": "/reset-password",  "destination": "/reset-password.html" },
    { "source": "/pricing",         "destination": "/pricing.html" },
    { "source": "/help",            "destination": "/help.html" },
    { "source": "/support",         "destination": "/support.html" },
    { "source": "/terms",           "destination": "/terms.html" },
    { "source": "/privacy",         "destination": "/privacy.html" },
    { "source": "/refund",          "destination": "/refund.html" },
    { "source": "/profile",          "destination": "/profile.html" },
    { "source": "/payment-method",   "destination": "/payment-method.html" },
    { "source": "/faq",              "destination": "/faq.html" },
    { "source": "/features",         "destination": "/features.html" },
    { "source": "/about",            "destination": "/about.html" },
    { "source": "/security",         "destination": "/security.html" },
    { "source": "/blog",             "destination": "/blog.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|otf|png|jpg|jpeg|gif|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/assets/favicon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ]
}
