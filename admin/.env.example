# TradingGrove local admin - copy this file to admin/.env and fill it in.
# NEVER commit admin/.env. NEVER put these values anywhere under src/.

# Supabase project (Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://oixrpuqylidbunbttftg.supabase.co
# The SERVICE ROLE key (secret). This bypasses RLS - keep it on this machine only.
SUPABASE_SERVICE_ROLE_KEY=

# Admin login for the local panel
ADMIN_USER=Rafael
ADMIN_PASS=admin123

# Local port (server binds to 127.0.0.1 only)
PORT=5600

# Optional: Cloudflare R2 (S3 API) credentials for accurate storage usage.
# Create an R2 API token with Object Read permission in the Cloudflare
# dashboard: R2 -> Manage R2 API Tokens -> Create API token. The account ID
# is shown on that same page (also in the S3 endpoint). Without these three,
# the panel shows image counts + Supabase Storage bytes only.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The live trade-screenshot bucket for this project is tradezona-images
# (NOT the Supabase Storage fallback bucket, which is named trade-images).
R2_BUCKET_NAME=tradezona-images

# Optional: set MOCK=1 to run the UI against fixture data (no Supabase calls)
MOCK=0
