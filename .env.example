# TradingGrove — Supabase Secrets Template
# Copy this file to supabase/.env and fill in your own values.
# These secrets are used by Supabase Edge Functions.
# NEVER commit actual secrets — only this template.

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Payment Processing)
PAYPAL_CLIENT_ID=AZ...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...
PAYPAL_MODE=live
PAYPAL_MONTHLY_PLAN_ID=P-...
PAYPAL_ANNUAL_PLAN_ID=P-...

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=trade-images
R2_ENDPOINT=https://{account-id}.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://{custom-domain-or-r2-url}

# Application
APP_URL=https://yourdomain.com
